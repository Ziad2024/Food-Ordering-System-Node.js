# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas — Replace with your Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Redis — Replace with your Railway Redis or Upstash URL
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# OR use a single Redis URL (preferred for Railway / Upstash):
# REDIS_URL=redis://default:<password>@<host>:<port>

# JWT Secrets — Generate strong random secrets (min 64 chars)
JWT_ACCESS_SECRET=replace_with_strong_random_64_char_secret
JWT_REFRESH_SECRET=replace_with_different_strong_random_64_char_secret

# Frontend URL — Set to your deployed Netlify URL
FRONTEND_URL=https://your-app.netlify.app

# SMTP / Email (Gmail example — use App Password, not account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Food Ordering System" <noreply@yourapp.com>

# Cloudinary — Get from cloudinary.com dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe — Get from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook secret — Get from Stripe dashboard > Webhooks after adding endpoint
STRIPE_WEBHOOK_SECRET=whsec_...
